<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend Settings form to add Foggy MCP configuration -->
    <record id="res_config_settings_view_form_foggy" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.foggy</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Foggy MCP" name="foggy_mcp" groups="base.group_system">
                    <block title="Engine Mode">
                        <setting string="Engine Mode"
                                 help="Embedded mode runs the Python engine inside Odoo with no external server. Gateway mode forwards requests to an external Foggy service, which is useful when you want the engine deployed separately.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="foggy_engine_mode" widget="radio"/>
                                </div>
                                <field name="foggy_embedded_available" invisible="1"/>
                                <div class="alert alert-info mt8" role="alert"
                                     invisible="foggy_engine_mode != 'embedded' or not foggy_embedded_available">
                                    <strong>Embedded mode:</strong> the query engine runs inside the Odoo process. No external server is required.
                                </div>
                                <div class="alert alert-warning mt8" role="alert"
                                     invisible="foggy_engine_mode != 'embedded' or foggy_embedded_available">
                                    <strong>`foggy-python` is not installed.</strong>
                                    Install it in the Odoo Python environment: <code>pip install foggy-python</code>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Quick Setup">
                        <setting string="Setup Wizard"
                                 help="Guided setup for engine configuration, closure-table initialization, and connection checks. Save your current settings before launching it.">
                            <div class="content-group">
                                <div class="mt16">
                                    <button name="%(foggy_setup_wizard_action)d"
                                            string="Launch Setup Wizard"
                                            type="action" class="btn-primary"/>
                                    <span class="text-muted ms-2">Launching the wizard will save the current settings first.</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Foggy MCP Server Connection"
                           invisible="foggy_engine_mode == 'embedded'">
                        <setting string="Server URL" help="Base URL of the Foggy MCP Server">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_url" class="col-lg-3"/>
                                    <field name="foggy_mcp_url" class="col-lg-6"
                                           placeholder="http://foggy-mcp:8080"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Endpoint Path" help="MCP JSON-RPC endpoint path">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_endpoint" class="col-lg-3"/>
                                    <field name="foggy_mcp_endpoint" class="col-lg-6"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Request Timeout" help="HTTP timeout in seconds">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_timeout" class="col-lg-3"/>
                                    <field name="foggy_mcp_timeout" class="col-lg-3"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Test Connection" help="Verify connectivity to the Foggy MCP Server">
                            <div class="content-group">
                                <div class="mt16">
                                    <button name="action_test_connection"
                                            string="Test Connection"
                                            type="object" class="btn-primary"/>
                                </div>
                                <field name="foggy_connection_status"
                                       class="mt16"
                                       nolabel="1"
                                       colspan="2"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Advanced Settings"
                           invisible="foggy_engine_mode == 'embedded'">
                        <setting string="Namespace" help="Model namespace used by the Foggy bundle">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_namespace" class="col-lg-3"/>
                                    <field name="foggy_mcp_namespace" class="col-lg-4"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Tool Cache TTL" help="How long to cache tool definitions, in seconds">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_cache_ttl" class="col-lg-3"/>
                                    <field name="foggy_mcp_cache_ttl" class="col-lg-3"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Auth Token" help="Bearer token used to authenticate with the Foggy MCP Server. Leave empty if auth is disabled on the server.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_mcp_auth_token" class="col-lg-3"/>
                                    <field name="foggy_mcp_auth_token" class="col-lg-6" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="权限映射状态">
                        <setting string="字段映射扫描"
                                 help="扫描所有 QM 模型对应 Odoo 模型的 ir.rule 记录，检查权限字段的映射覆盖率。未映射的字段将导致查询被拒绝（fail-closed）。">
                            <div class="content-group">
                                <div class="mt16">
                                    <button name="action_refresh_mapping_status"
                                            string="刷新映射"
                                            type="object" class="btn-primary"/>
                                    <button name="action_view_mapping_status"
                                            string="查看映射状态"
                                            type="object" class="btn-secondary ms-2"/>
                                </div>
                                <field name="foggy_mapping_total_count" invisible="1"/>
                                <field name="foggy_unmapped_field_count" invisible="1"/>
                                <div class="alert alert-success mt16" role="alert"
                                     invisible="foggy_mapping_total_count == 0 or foggy_unmapped_field_count &gt; 0">
                                    <strong>✅ 所有权限字段已映射</strong>
                                    （共 <field name="foggy_mapping_total_count" class="d-inline" nolabel="1" readonly="1"/> 个字段）
                                </div>
                                <div class="alert alert-info mt16" role="alert"
                                     invisible="foggy_unmapped_field_count == 0">
                                    <strong>ℹ️ 存在 <field name="foggy_unmapped_field_count" class="d-inline" nolabel="1" readonly="1"/> 个未映射字段</strong>
                                    ，请在映射状态列表中查看详情。
                                </div>
                                <div class="text-muted mt8"
                                     invisible="foggy_mapping_total_count != 0">
                                    尚未执行扫描，请点击「刷新映射」按钮。
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="AI Chat (LLM Settings)">
                        <setting string="LLM Provider" help="Select the model provider used by the built-in AI chat feature">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_llm_provider" class="col-lg-3"/>
                                    <field name="foggy_llm_provider" class="col-lg-4"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="API Key" help="API key for the selected LLM provider">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_llm_api_key" class="col-lg-3"/>
                                    <field name="foggy_llm_api_key" class="col-lg-6" password="True"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Model Name" help="Model identifier, for example gpt-4o-mini, claude-3-5-sonnet-20241022, or deepseek-chat">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_llm_model" class="col-lg-3"/>
                                    <field name="foggy_llm_model" class="col-lg-4"
                                           placeholder="gpt-4o-mini"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="API Base URL" help="Custom endpoint URL for non-default providers such as DeepSeek or Ollama">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_llm_base_url" class="col-lg-3"/>
                                    <field name="foggy_llm_base_url" class="col-lg-6"
                                           placeholder="http://localhost:11434/v1"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Temperature" help="Controls randomness (0.0 = deterministic, 1.0 = creative)">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="foggy_llm_temperature" class="col-lg-3"/>
                                    <field name="foggy_llm_temperature" class="col-lg-2"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Business Context &amp; Custom Rules"
                                 help="Custom instructions injected into every AI chat. Use this for business terms, KPIs, and answer rules. Core safety rules still apply.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="foggy_llm_custom_prompt" widget="text"
                                           placeholder="Example:&#10;&#10;## Business terms&#10;- Enterprise account = annual revenue above 500k&#10;- Active customer = at least one order in the last 90 days&#10;- Fiscal year starts in April&#10;&#10;## Extra rules&#10;- Hide employee mobile numbers&#10;- Use CNY as the default currency&#10;- R&amp;D includes QA and DevOps"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
