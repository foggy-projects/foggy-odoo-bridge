<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- API Key 列表视图 -->
    <record id="foggy_api_key_view_tree" model="ir.ui.view">
        <field name="name">foggy.api.key.tree</field>
        <field name="model">foggy.api.key</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" string="Name"/>
                <field name="user_id" string="User"/>
                <field name="key_short" string="Key Preview"/>
                <field name="active" string="Active" widget="boolean_toggle"/>
                <field name="last_used" string="Last Used"/>
                <field name="create_date" string="Created On"/>
            </tree>
        </field>
    </record>

    <!-- API Key 表单视图 -->
    <record id="foggy_api_key_view_form" model="ir.ui.view">
        <field name="name">foggy.api.key.form</field>
        <field name="model">foggy.api.key</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_regenerate_key" string="Regenerate Key"
                            type="object" class="btn-warning"
                            confirm="This will invalidate the current key. Continue?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Example: Claude Desktop - Work Laptop"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="key" widget="CopyClipboardChar"/>
                            <field name="mcp_endpoint" widget="CopyClipboardChar"/>
                            <field name="last_used"/>
                        </group>
                    </group>
                    <group string="Restrictions">
                        <field name="company_ids" widget="many2many_tags"/>
                    </group>
                    <separator string="Connection Guide"/>
                    <div class="alert alert-success" role="alert">
                        <p><strong>Ready-to-use config:</strong></p>
                        <field name="mcp_config_html" widget="html" readonly="1" nolabel="1"/>
                        <p class="mb-0 text-muted"><small>Select the JSON and press Ctrl+C / Cmd+C to copy it. You can also copy the API key and MCP endpoint separately above.</small></p>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <p><strong>Generic template for other environments:</strong></p>
                        <p>Replace <code>&lt;your-odoo-url&gt;</code> and <code>&lt;your-api-key&gt;</code> with your actual values:</p>
                        <pre style="background:#f8f9fa; padding:12px; border-radius:4px; font-size:13px;">{
  "mcpServers": {
    "odoo": {
      "url": "https://&lt;your-odoo-url&gt;/foggy-mcp/rpc",
      "headers": {
        "Authorization": "Bearer &lt;your-api-key&gt;"
      }
    }
  }
}</pre>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Key 操作 -->
    <record id="foggy_api_key_action" model="ir.actions.act_window">
        <field name="name">MCP API Keys</field>
        <field name="res_model">foggy.api.key</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create an API key
            </p>
            <p>
                API keys allow AI clients such as Claude Desktop and Cursor
                to connect to Odoo securely over MCP.
            </p>
        </field>
    </record>

    <!-- "我的 API 密钥" 操作 — 直接打开当前用户的密钥 -->
    <record id="foggy_my_api_key_action" model="ir.actions.act_window">
        <field name="name">My API Keys</field>
        <field name="res_model">foggy.api.key</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No API keys yet
            </p>
            <p>
                Click <strong>New</strong> to create a Foggy MCP API key,
                then use it with Claude Desktop, Cursor, or any other MCP-compatible AI client.
            </p>
        </field>
    </record>

    <!-- "我的 API 密钥" 菜单 — 位于设置 → Foggy MCP 下 -->
    <menuitem id="foggy_mcp_user_menu_my_key"
              name="MCP API Keys"
              parent="foggy_mcp_menu_root"
              action="foggy_my_api_key_action"
              sequence="20"
              groups="foggy_mcp.group_foggy_mcp_user"/>

    <menuitem id="foggy_mcp_menu_api_keys"
              name="API Keys (All Users)"
              parent="foggy_mcp_menu_root"
              action="foggy_api_key_action"
              sequence="10"
              groups="foggy_mcp.group_foggy_admin"/>
</odoo>
