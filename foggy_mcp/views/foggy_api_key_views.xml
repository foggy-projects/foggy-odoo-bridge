<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- API Key 列表视图 -->
    <record id="foggy_api_key_view_tree" model="ir.ui.view">
        <field name="name">foggy.api.key.tree</field>
        <field name="model">foggy.api.key</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="user_id"/>
                <field name="key_short"/>
                <field name="active"/>
                <field name="last_used"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- API Key 表单视图 -->
    <record id="foggy_api_key_view_form" model="ir.ui.view">
        <field name="name">foggy.api.key.form</field>
        <field name="model">foggy.api.key</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_regenerate_key" string="重新生成密钥"
                            type="object" class="btn-warning"
                            confirm="这将使当前密钥失效，是否继续？"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="例如：Claude Desktop - 工作电脑"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="key" widget="CopyClipboardChar"/>
                            <field name="mcp_endpoint" widget="CopyClipboardChar"/>
                            <field name="last_used"/>
                        </group>
                    </group>
                    <group string="限制">
                        <field name="company_ids" widget="many2many_tags"/>
                    </group>
                    <separator string="连接说明"/>
                    <div class="alert alert-success" role="alert">
                        <p><strong>即用配置：</strong></p>
                        <field name="mcp_config_html" widget="html" readonly="1" nolabel="1"/>
                        <p class="mb-0 text-muted"><small>选中 JSON 文本后按 Ctrl+C / ⌘+C 复制。也可单独复制上方的 API 密钥和 MCP 端点。</small></p>
                    </div>
                    <div class="alert alert-info" role="alert">
                        <p><strong>通用模板（适用于其他环境）：</strong></p>
                        <p>请将 <code>&lt;your-odoo-url&gt;</code> 和 <code>&lt;your-api-key&gt;</code> 替换为实际值：</p>
                        <pre style="background:#f8f9fa; padding:12px; border-radius:4px; font-size:13px;">{
  "mcpServers": {
    "odoo": {
      "url": "https://&lt;your-odoo-url&gt;/foggy-mcp/rpc",
      "headers": {
        "Authorization": "Bearer &lt;your-api-key&gt;"
      }
    }
  }
}</pre>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- API Key 操作 -->
    <record id="foggy_api_key_action" model="ir.actions.act_window">
        <field name="name">MCP API 密钥</field>
        <field name="res_model">foggy.api.key</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                创建 API 密钥
            </p>
            <p>
                API 密钥允许 AI 客户端（Claude Desktop、Cursor 等）
                通过 MCP 协议安全连接到 Odoo。
            </p>
        </field>
    </record>

    <!-- "我的 API 密钥" 操作 — 直接打开当前用户的密钥 -->
    <record id="foggy_my_api_key_action" model="ir.actions.act_window">
        <field name="name">我的 API 密钥</field>
        <field name="res_model">foggy.api.key</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="context">{'default_user_id': uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无 API 密钥
            </p>
            <p>
                点击 <strong>新建</strong> 创建 Foggy MCP API 密钥，
                然后在 Claude Desktop、Cursor 或其他兼容 MCP 的 AI 客户端中使用。
            </p>
        </field>
    </record>

    <!-- "我的 API 密钥" 菜单 — 位于设置 → Foggy MCP 下 -->
    <menuitem id="foggy_mcp_user_menu_my_key"
              name="MCP API 密钥"
              parent="foggy_mcp_config_menu_root"
              action="foggy_my_api_key_action"
              sequence="20"
              groups="base.group_user"/>

    <!-- 管理员菜单（位于设置下） -->
    <menuitem id="foggy_mcp_menu_root"
              name="Foggy MCP"
              parent="base.menu_administration"
              sequence="100"/>

    <menuitem id="foggy_mcp_menu_api_keys"
              name="API 密钥（所有用户）"
              parent="foggy_mcp_menu_root"
              action="foggy_api_key_action"
              sequence="10"/>
</odoo>
