<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 连接测试结果对话框 -->
    <record id="foggy_connection_test_result_view_form" model="ir.ui.view">
        <field name="name">foggy.connection.test.result.view.form</field>
        <field name="model">foggy.connection.test.result</field>
        <field name="arch" type="xml">
            <form string="连接测试结果">
                <group>
                    <field name="status_message" nolabel="1" colspan="2"/>
                </group>
                <footer>
                    <button string="关闭" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
