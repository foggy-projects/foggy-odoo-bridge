<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="foggy_mcp.FoggyChat">
        <div class="foggy-chat-container d-flex h-100">
            <!-- Sidebar -->
            <div t-attf-class="foggy-chat-sidebar {{ state.sidebarOpen ? '' : 'd-none' }}">
                <div class="foggy-sidebar-header">
                    <button class="btn btn-primary btn-sm w-100" t-on-click="newChat">
                        <i class="fa fa-plus me-1"/><t t-_t="">New Chat</t>
                    </button>
                </div>
                <div class="foggy-session-list">
                    <t t-foreach="state.sessions" t-as="session" t-key="session.id">
                        <div t-attf-class="foggy-session-item {{ state.currentSessionId === session.id ? 'active' : '' }}"
                             t-on-click="() => this.selectSession(session.id)">
                            <span class="foggy-session-name" t-esc="session.name"/>
                            <button class="foggy-session-delete btn btn-link btn-sm text-danger p-0"
                                    t-on-click="(ev) => this.deleteSession(ev, session.id)"
                                    t-att-title="_t('Delete')">
                                <i class="fa fa-trash-o"/>
                            </button>
                        </div>
                    </t>
                    <div t-if="!state.sessions.length" class="text-muted p-3 text-center">
                        <small><t t-_t="">No conversations yet</t></small>
                    </div>
                </div>
            </div>

            <!-- Main Chat Area -->
            <div class="foggy-chat-main flex-grow-1 d-flex flex-column">
                <!-- Header -->
                <div class="foggy-chat-header d-flex align-items-center px-3 py-2">
                    <button class="btn btn-link btn-sm me-2" t-on-click="toggleSidebar">
                        <i class="fa fa-bars"/>
                    </button>
                    <h5 class="mb-0">
                        <i class="fa fa-magic me-2 text-primary"/><t t-_t="">Foggy AI</t>
                    </h5>
                    <span class="badge bg-success ms-2"><t t-_t="">Data Analyst</t></span>
                </div>

                <!-- Messages -->
                <div class="foggy-chat-messages flex-grow-1 overflow-auto px-3 py-2">
                    <!-- Welcome message when empty -->
                    <t t-if="!state.messages.length">
                        <div class="foggy-welcome text-center py-5">
                            <div class="foggy-welcome-icon mb-3">
                                <i class="fa fa-database fa-3x text-primary"/>
                            </div>
                            <h4><t t-_t="">Foggy AI Data Analyst</t></h4>
                            <p class="text-muted"><t t-_t="">Ask questions about your business data in natural language.</t></p>
                            <div class="foggy-suggestions d-flex flex-wrap justify-content-center gap-2 mt-3">
                                <button class="btn btn-outline-primary btn-sm"
                                        t-on-click="() => { this.state.inputText = 'Show me the top 5 customers by total sales revenue'; this.sendMessage(); }">
                                    <t t-_t="">📊 Top customers by revenue</t>
                                </button>
                                <button class="btn btn-outline-primary btn-sm"
                                        t-on-click="() => { this.state.inputText = 'What is the total sales amount by month for the last 6 months?'; this.sendMessage(); }">
                                    <t t-_t="">📈 Monthly sales trend</t>
                                </button>
                                <button class="btn btn-outline-primary btn-sm"
                                        t-on-click="() => { this.state.inputText = 'Show CRM pipeline: lead count and expected revenue by stage'; this.sendMessage(); }">
                                    <t t-_t="">🎯 CRM pipeline overview</t>
                                </button>
                            </div>
                        </div>
                    </t>

                    <!-- Message list -->
                    <t t-foreach="state.messages" t-as="msg" t-key="msg_index">
                        <div t-attf-class="foggy-message foggy-message-{{ msg.role }} mb-3">
                            <div class="foggy-message-avatar">
                                <t t-if="msg.role === 'user'">
                                    <i class="fa fa-user"/>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-magic"/>
                                </t>
                            </div>
                            <div class="foggy-message-content">
                                <t t-if="msg.role === 'user'">
                                    <t t-esc="msg.content"/>
                                </t>
                                <t t-else="">
                                    <t t-out="this.formatContent(msg.content)"/>
                                </t>
                            </div>
                        </div>
                    </t>

                    <!-- Loading indicator -->
                    <div t-if="state.loading" class="foggy-message foggy-message-assistant mb-3">
                        <div class="foggy-message-avatar">
                            <i class="fa fa-magic"/>
                        </div>
                        <div class="foggy-message-content">
                            <div class="foggy-typing">
                                <span class="foggy-dot"/>
                                <span class="foggy-dot"/>
                                <span class="foggy-dot"/>
                            </div>
                        </div>
                    </div>

                    <div t-ref="messagesEnd"/>
                </div>

                <!-- Input Area -->
                <div class="foggy-chat-input-area px-3 py-2">
                    <div class="foggy-input-wrapper d-flex align-items-end gap-2">
                        <textarea
                            t-ref="chatInput"
                            class="form-control foggy-input"
                            t-att-value="state.inputText"
                            t-on-input="(ev) => { this.state.inputText = ev.target.value; }"
                            t-on-keydown="onKeydown"
                            t-att-placeholder="_t('Ask about your business data...')"
                            rows="1"
                            t-att-disabled="state.loading"
                        />
                        <button
                            class="btn btn-primary foggy-send-btn"
                            t-on-click="sendMessage"
                            t-att-disabled="state.loading || !state.inputText.trim()">
                            <i t-attf-class="fa {{ state.loading ? 'fa-spinner fa-spin' : 'fa-paper-plane' }}"/>
                        </button>
                    </div>
                    <div class="foggy-input-hint text-muted mt-1">
                        <small><t t-_t="">Press Enter to send, Shift+Enter for new line</t></small>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
