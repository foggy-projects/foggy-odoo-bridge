<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Setup Wizard Form View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="foggy_setup_wizard_view_form" model="ir.ui.view">
        <field name="name">foggy.setup.wizard.form</field>
        <field name="model">foggy.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="Foggy MCP Setup Wizard">
                <field name="state" invisible="1"/>
                <field name="engine_mode" invisible="1"/>
                <field name="embedded_available" invisible="1"/>

                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="welcome,deploy,connection,datasource,closure,done"
                           invisible="engine_mode == 'embedded'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="welcome,closure,done"
                           invisible="engine_mode != 'embedded'"/>
                </header>

                <sheet>
                    <!-- 第 1 步：欢迎 -->
                    <div invisible="state != 'welcome'">
                        <div class="oe_title mb24">
                            <h2>Welcome to Foggy MCP</h2>
                            <p class="text-muted">
                                This wizard helps you connect Odoo to Claude, Cursor, and other AI assistants.
                            </p>
                        </div>

                        <!-- 引擎模式选择 -->
                        <group string="Choose Engine Mode">
                            <field name="engine_mode" widget="radio" nolabel="1"
                                   colspan="2"/>
                        </group>

                        <!-- 网关模式提示 -->
                        <div class="alert alert-info" role="alert"
                             invisible="engine_mode != 'gateway'">
                            <strong>You will need:</strong>
                            <ul class="mb0 mt4">
                                <li>Docker installed on the target server</li>
                                <li>Terminal access</li>
                                <li>About 2 minutes</li>
                            </ul>
                        </div>

                        <!-- 内嵌模式提示 -->
                        <div class="alert alert-success" role="alert"
                             invisible="engine_mode != 'embedded' or not embedded_available">
                            <strong>Embedded mode is ready</strong>
                            <p class="mb0 mt4">
                                The query engine will run inside the Odoo process. No external service is required.
                                Click "Next" to continue.
                            </p>
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="engine_mode != 'embedded' or embedded_available">
                            <strong>`foggy-python` is not installed</strong>
                            <p class="mb0 mt4">
                                Install it in the Odoo Python environment: <code>pip install foggy-python</code>
                            </p>
                        </div>

                        <!-- 内嵌引擎测试结果 -->
                        <group string="Engine Status" invisible="not embedded_status">
                            <field name="embedded_status" nolabel="1"
                                   widget="text" readonly="1"/>
                        </group>
                    </div>

                    <!-- 第 2 步：部署 -->
                    <div invisible="state != 'deploy'">
                        <div class="oe_title mb16">
                            <h2>Deploy Foggy MCP Server</h2>
                            <p class="text-muted">
                                The wizard detected database settings from Odoo. Adjust them if needed, then run the command below in your terminal.
                            </p>
                        </div>

                        <!-- Docker 网络检测 - 真实网络名称（Docker socket 已挂载） -->
                        <div invisible="not docker_network_name" class="alert alert-success mb16" role="alert">
                            <strong>Docker network detected:</strong>
                            <span>Odoo is running in Docker network <code><field name="docker_network_name"/></code></span>
                            <br/>
                            <small>Foggy MCP will join the same network automatically for seamless connectivity.</small>
                        </div>

                        <!-- Docker 网络检测 - 推断（无 Docker socket） -->
                        <div invisible="not docker_network_detected or docker_network_name" class="alert alert-warning mb16" role="alert">
                            <strong>Docker environment detected (socket not mounted)</strong>
                            <br/>
                            <small>Odoo is running in Docker, but the Docker socket is not mounted.
                            The generated command includes a placeholder network name that you must replace manually.</small>
                            <br/>
                            <code style="margin-top: 4px; display: inline-block;">docker network ls</code>
                        </div>

                        <!-- 连接模式选择 -->
                        <group string="Connection Mode">
                            <field name="connection_mode" widget="radio"
                                   nolabel="1" colspan="2"/>
                        </group>

                        <!-- Docker 网络模式设置 -->
                        <div invisible="connection_mode != 'docker'" class="mb16">
                            <group string="Docker Network Settings" col="4">
                                <field name="docker_network_input"
                                       placeholder="odoo_default"
                                       help="Enter a Docker network name. Run `docker network ls` to inspect available networks."/>
                            </group>
                            <div class="alert alert-info mb8" role="alert">
                                <strong>How it works:</strong>
                                <span class="text-muted">The Foggy container will join this network and reach the database through Docker service names.</span>
                            </div>
                        </div>

                        <!-- 直接 IP 连接模式设置 -->
                        <div invisible="connection_mode != 'direct_ip'" class="mb16">
                            <group string="Direct IP Settings" col="4">
                                <field name="custom_db_host"
                                       placeholder="192.168.1.100"
                                       help="Enter the IP address of the Odoo database host."/>
                            </group>
                            <div class="alert alert-info mb8" role="alert">
                                <strong>How it works:</strong>
                                <span class="text-muted">The Foggy container will connect directly to the database host over IP. This is often preferable in production.</span>
                            </div>
                        </div>

                        <!-- 数据库配置（从 Odoo 自动读取，只读） -->
                        <group string="Database Settings Read from Odoo (Read-only)">
                            <group>
                                <field name="db_host" readonly="1" force_save="1"/>
                                <field name="db_port" readonly="1" force_save="1"/>
                                <field name="db_user" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="db_password" password="True" readonly="1" force_save="1"/>
                                <field name="db_name" readonly="1" force_save="1"/>
                                <field name="foggy_port"/>
                            </group>
                        </group>

                        <!-- 隐藏字段 -->
                        <field name="docker_network_name" invisible="1"/>
                        <field name="docker_network_mode" invisible="1"/>
                        <field name="docker_network_detected" invisible="1"/>
                        <field name="docker_socket_available" invisible="1"/>

                        <div class="mt8 mb8">
                            <button name="action_regenerate_command" string="Regenerate Command"
                                    type="object" class="btn-secondary btn-sm"/>
                        </div>

                        <separator string="Run this command in your terminal"/>
                        <field name="deploy_command"
                               widget="ace" options="{'mode': 'sh'}"
                               readonly="1" nolabel="1"
                               class="mb16"/>

                        <div class="alert alert-secondary" role="alert">
                            <strong>Steps:</strong>
                            <ol class="mb0 mt4">
                                <li>Select the command above, press <code>Ctrl+A</code>, then <code>Ctrl+C</code> to copy it.</li>
                                <li>Open a terminal session (SSH or local terminal).</li>
                                <li>Paste the command and run it.</li>
                                <li>Wait until the server starts, then click "Next".</li>
                            </ol>
                        </div>
                    </div>

                    <!-- 第 3 步：连接测试 -->
                    <div invisible="state != 'connection'">
                        <div class="oe_title mb16">
                            <h2>Test Connection</h2>
                            <p class="text-muted">
                                Verify that the Foggy MCP Server is reachable. Successful tests are saved automatically.
                            </p>
                        </div>

                        <!-- Docker 网络提示 - 真实网络 -->
                        <div invisible="not docker_network_name" class="alert alert-info mb8" role="alert">
                            <strong>Tip:</strong> Because both containers are on network <code><field name="docker_network_name"/></code>,
                            use <code>http://foggy-mcp:8080</code> as the URL.
                        </div>

                        <!-- Docker 网络提示 - 无 socket 但在 Docker 中 -->
                        <div invisible="not docker_network_detected or docker_network_name" class="alert alert-info mb8" role="alert">
                            <strong>Tip:</strong> If both containers share the same Docker network,
                            use <code>http://foggy-mcp:8080</code> as the URL.
                        </div>

                        <group string="Foggy MCP Server URL">
                            <field name="foggy_url" placeholder="http://localhost:7108"/>
                        </group>

                        <group string="Test Result" invisible="not connection_status">
                            <field name="connection_status" nolabel="1"
                                   widget="text" readonly="1"/>
                        </group>

                        <div invisible="connection_status" class="alert alert-warning" role="alert">
                            Click <strong>Test Connection</strong> below to verify the server.
                        </div>

                        <div invisible="not connection_status or 'Unable to connect' in connection_status or 'HTTP' in connection_status" class="alert alert-success mb16" role="alert">
                            <strong>Connection looks good.</strong>
                            <p class="mb0 mt4">
                                The configuration has already been saved automatically. Use the button below if you want to save the current values again manually.
                            </p>
                        </div>

                        <div class="mt8 mb8" invisible="not connection_status or 'Unable to connect' in connection_status or 'HTTP' in connection_status">
                            <button name="action_save_connection" string="Save Current Configuration"
                                    type="object" class="btn-secondary"/>
                        </div>
                    </div>

                    <!-- 第 4 步：数据源 -->
                    <div invisible="state != 'datasource'">
                        <div class="oe_title mb16">
                            <h2>Configure Data Source</h2>
                            <p class="text-muted">
                                Register the Odoo database as a data source in Foggy MCP Server.
                            </p>
                        </div>

                        <!-- 连接模式摘要 -->
                        <div class="alert alert-info mb16" role="alert">
                            <strong>Current connection mode:</strong>
                            <span invisible="connection_mode != 'docker'">
                                <strong>Docker Network</strong> - Foggy reaches the database over a shared Docker network
                                <br/>
                                <small>Database host: <code>postgres</code> (or the service name detected from Odoo)</small>
                            </span>
                            <span invisible="connection_mode != 'direct_ip'">
                                <strong>Direct IP Connection</strong> - Foggy reaches the database over a specific host IP
                                <br/>
                                <small>Database host: <code><field name="custom_db_host" class="font-weight-bold"/></code></small>
                            </span>
                        </div>

                        <!-- 数据源配置预览 -->
                        <group string="Data Source Preview">
                            <group>
                                <field name="db_host" readonly="1" force_save="1" string="Database Host"/>
                                <field name="db_port" readonly="1" force_save="1" string="Database Port"/>
                            </group>
                            <group>
                                <field name="db_user" readonly="1" force_save="1" string="Database User"/>
                                <field name="db_name" readonly="1" force_save="1" string="Database Name"/>
                            </group>
                        </group>

                        <div class="mt16 mb16">
                            <button name="action_configure_datasource"
                                    string="Register Data Source"
                                    type="object" class="btn-primary"/>
                        </div>

                        <group string="Registration Result" invisible="not datasource_status">
                            <field name="datasource_status" nolabel="1"
                                   widget="text" readonly="1"/>
                        </group>
                    </div>

                    <!-- 第 5 步：闭包表 -->
                    <div invisible="state != 'closure'">
                        <div class="oe_title mb16">
                            <h2>Initialize Closure Tables</h2>
                            <p class="text-muted">
                                Hierarchical queries such as company trees and department trees work best with closure tables.
                            </p>
                        </div>

                        <div class="mt16 mb16">
                            <button name="action_init_closure_tables"
                                    string="Initialize Closure Tables"
                                    type="object" class="btn-primary"
                                    confirm="This will create 4 closure tables in the database. Continue?"/>
                        </div>

                        <group string="Execution Result" invisible="not closure_status">
                            <field name="closure_status" nolabel="1"
                                   widget="text" readonly="1"/>
                        </group>

                        <div class="alert alert-secondary" role="alert">
                            <strong>Closure tables:</strong> res_company_closure, hr_department_closure, hr_employee_closure, res_partner_closure
                            <br/><br/>
                            <strong>Tip:</strong> If you do not need hierarchy-aware queries yet, you can skip this step and run it later from settings.
                        </div>
                    </div>

                    <!-- 第 6 步：完成 -->
                    <div invisible="state != 'done'">
                        <div class="oe_title mb16">
                            <h2>Setup Complete</h2>
                        </div>
                        <div class="alert alert-success" role="alert">
                            <p><strong>Foggy MCP is ready.</strong></p>
                            <p class="mt8 mb0">
                                Next step: create an API key and connect your AI assistant.
                            </p>
                        </div>
                    </div>
                </sheet>

                <!-- 底部按钮 -->
                <footer>
                    <button name="action_next" string="Next →"
                            type="object" class="btn-primary"
                            invisible="state not in ('welcome', 'deploy', 'connection', 'datasource')"/>
                    <button name="action_test_connection" string="Test Connection"
                            type="object" class="btn-primary"
                            invisible="state != 'connection'"/>
                    <button name="action_configure_datasource" string="Register Data Source"
                            type="object" class="btn-primary"
                            invisible="state != 'datasource'"/>
                    <button name="action_init_closure_tables" string="Initialize Closure Tables"
                            type="object" class="btn-primary"
                            invisible="state != 'closure'"/>
                    <button name="action_skip_closure" string="Skip"
                            type="object" class="btn-secondary"
                            invisible="state != 'closure'"/>
                    <button name="action_finish" string="Create API Key"
                            type="object" class="btn-success"
                            invisible="state != 'done'"/>
                    <button name="action_prev" string="← Previous"
                            type="object" class="btn-secondary"
                            invisible="state in ('welcome', 'done')"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="foggy_setup_wizard_action" model="ir.actions.act_window">
        <field name="name">Foggy MCP Setup Wizard</field>
        <field name="res_model">foggy.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu -->
    <menuitem id="foggy_mcp_menu_setup_wizard"
              name="Setup Wizard"
              parent="foggy_mcp_menu_root"
              action="foggy_setup_wizard_action"
              sequence="1"/>

</odoo>
