<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- Users can only see their own API keys -->
        <record id="foggy_api_key_rule_user" model="ir.rule">
            <field name="name">Foggy API Key: Own Keys Only</field>
            <field name="model_id" ref="model_foggy_api_key"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Admins can see all API keys -->
        <record id="foggy_api_key_rule_admin" model="ir.rule">
            <field name="name">Foggy API Key: Admin Full Access</field>
            <field name="model_id" ref="model_foggy_api_key"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
